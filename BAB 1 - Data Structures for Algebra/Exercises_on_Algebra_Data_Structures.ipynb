        "import numpy as np\n",
        "\n",
        "# What is the transpose of this vector\n",
        "\n",
        "vector = np.array([[25],[2],[-3],[-23]])\n",
        "print(\"Vector =\")\n",
        "print(vector)\n",
        "\n",
        "vector_transpose = vector.T\n",
        "print(\"Vector Transpose =\")\n",
        "print(vector_transpose)"
      ],
